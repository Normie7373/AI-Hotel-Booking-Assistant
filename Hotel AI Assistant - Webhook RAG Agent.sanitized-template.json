                      "parameters":  {
                                         "jsCode":  "return items.map(item =\u003e {\n    const data = item.json;\n    let content = \"\";\n\n    if (data.Question \u0026\u0026 data.Answer) {\n        // FAQ format\n        content = `FAQ\\nQ: ${data.Question}\\nA: ${data.Answer}`;\n    } else if (data[\u0027Room Name\u0027] \u0026\u0026 data[\u0027Price Per Night\u0027]) {\n        // Hotel room format\n        content = `Room: ${data[\u0027Room Name\u0027]}\\nPrice: ${data[\u0027Price Per Night\u0027]}/night\\nCapacity: ${data[\u0027Max Guests\u0027] || \u0027N/A\u0027} guests\\nAmenities: ${data[\u0027Amenities\u0027] || \u0027N/A\u0027}\\nDescription: ${data[\u0027Description\u0027] || \u0027N/A\u0027}`;\n    } else if (data[\u0027Topic\u0027] \u0026\u0026 data[\u0027Details\u0027]) {\n        // General hotel info format\n        content = `Topic: ${data[\u0027Topic\u0027]}\\nDetails: ${data[\u0027Details\u0027]}`;\n    } else {\n        // Fallback\n        content = JSON.stringify(data);\n    }\n\n    return {\n        json: {\n            values: [],\n            content: content\n        }\n    };\n});\n"
                                     },
